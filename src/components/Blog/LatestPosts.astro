---
import { getCollection } from "astro:content";
import Section from "../UI/Section.astro";

const posts = (await getCollection("posts", ({ data }) => data.type === "blog_post"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 4);

const dateFmt = new Intl.DateTimeFormat("en-US", { dateStyle: "medium" });
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function excerpt(markdown: string): string {
  const text = markdown
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/[>#*_`]/g, " ")
    .replace(/\s+/g, " ")
    .trim();

  if (text.length <= 190) {
    return text;
  }

  return `${text.slice(0, 190)}...`;
}
---

<Section id="writing" title="Latest Writing" titleClassName="mb-12">
  <div class="w-full grid gap-6 md:grid-cols-2">
    {
      posts.map((post) => (
        <article class="rounded-2xl border border-white/10 bg-gray-900/60 p-6 transition hover:border-primary/50 hover:-translate-y-0.5">
          <div class="text-sm text-gray-400 mb-2">
            {dateFmt.format(post.data.publishedAt)}
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">
            <a href={`${base}/posts/${post.slug}/`} class="hover:text-primary transition-colors">
              {post.data.title}
            </a>
          </h3>
          <p class="text-gray-300 leading-relaxed mb-4">{excerpt(post.body)}</p>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs text-blue-300 bg-blue-900/30 px-2 py-1 rounded-full">#{tag}</span>
            ))}
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-8 text-center">
    <a
      href={`${base}/activity`}
      class="inline-flex items-center px-6 py-3 bg-primary hover:bg-secondary text-white font-semibold rounded-3xl transition-all duration-150 drop-shadow-[2px_2px_0_#1d4ed8] active:translate-0.5 active:drop-shadow-none"
    >
      View activity feed
    </a>
  </div>
</Section>
