---
import { Icon } from "astro-icon/components";

const stack = [
    { icon: "simple-icons:python",     label: "Python" },
    { icon: "simple-icons:pytorch",    label: "PyTorch" },
    { icon: "simple-icons:r",          label: "R" },
    { icon: "simple-icons:azuredevops", label: "Azure" },
    { icon: "simple-icons:amazonaws",  label: "AWS" },
    { icon: "simple-icons:postgresql", label: "SQL" },
    { icon: "simple-icons:c",          label: "C" },
    { icon: "simple-icons:git",        label: "Git" },
];
---

<section class="relative z-20 px-6">
    <div class="max-w-5xl mx-auto">
        <div class="bg-gray-900/40 backdrop-blur-xl rounded-3xl px-8 py-6 flex flex-col items-center gap-6">
            <span class="text-xs text-gray-500 uppercase tracking-widest">Tech Stack</span>
            <div class="flex flex-wrap justify-center gap-8">
            {stack.map((item) => (
                <div class="flex flex-col items-center gap-2 group">
                    <Icon
                        name={item.icon}
                        class="size-8 text-gray-400 group-hover:text-white transition-colors duration-300"
                    />
                    <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors duration-300 uppercase tracking-wider">
                        {item.label}
                    </span>
                </div>
            ))}
            </div>
        </div>
    </div>
</section>
