---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/UI/Section.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => data.type === "blog_post");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { Content } = await render(post);
const dateFmt = new Intl.DateTimeFormat("en-US", { dateStyle: "medium" });
---

<Layout>
  <Section id={`post-${post.slug}`} className="pt-32" titleClassName="hidden">
    <article class="w-full max-w-4xl rounded-2xl border border-white/10 bg-gray-900/70 p-8 md:p-10">
      <div class="text-sm text-gray-400 mb-3">
        {dateFmt.format(post.data.publishedAt)}
        {post.data.tags.length ? ` • ${post.data.tags.join(", ")}` : ""}
      </div>
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-6">{post.data.title}</h1>
      <div class="post-content text-gray-200 leading-relaxed">
        <Content />
      </div>
    </article>
  </Section>
</Layout>

<style>
  .post-content :global(h2),
  .post-content :global(h3) {
    color: white;
    margin-top: 2rem;
    margin-bottom: 0.8rem;
  }

  .post-content :global(p),
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 1rem;
  }

  .post-content :global(pre) {
    overflow-x: auto;
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .post-content :global(code) {
    color: #bfdbfe;
  }

  .post-content :global(a) {
    color: #93c5fd;
  }
</style>
