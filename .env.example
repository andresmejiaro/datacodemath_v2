# Shared secret used by the App when calling POST /api/publish
BLOG_API_SECRET=replace-with-strong-secret

# GitHub API credentials for creating markdown files in this repo
GITHUB_TOKEN=github_pat_with_repo_contents_write
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-blog-repo-name
GITHUB_BRANCH=main

# Public site URL (used in API response URLs)
SITE_URL=https://your-domain.com
